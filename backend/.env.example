# Azure Database for PostgreSQL connection string (preferred):
DATABASE_URL=postgresql://<user>:<password>@<server-name>.postgres.database.azure.com:5432/<database>?sslmode=require

# Alternatively, discrete values (used only if DATABASE_URL is not set):
# POSTGRES_HOST=<server-name>.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_USER=<user>
# POSTGRES_PASSWORD=<password>
# POSTGRES_DB=<database>
# POSTGRES_SSLMODE=require
